{
  "name": "@optio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "openapi:lint": "redocly lint openapi.generated.json",
    "openapi:types": "openapi-typescript openapi.generated.json -o openapi.generated.d.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.0.2",
    "@kubernetes/client-node": "^1.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.56.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.56.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.56.0",
    "@opentelemetry/exporter-prometheus": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.56.0",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-logs": "^0.56.0",
    "@opentelemetry/sdk-metrics": "^1.29.0",
    "@opentelemetry/sdk-node": "^0.56.0",
    "@opentelemetry/sdk-trace-node": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@optio/agent-adapters": "workspace:*",
    "@optio/container-runtime": "workspace:*",
    "@optio/shared": "workspace:*",
    "@optio/ticket-providers": "workspace:*",
    "bullmq": "^5.52.2",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^3.0.0",
    "ioredis": "^5.6.1",
    "jose": "^6.2.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.7",
    "web-push": "^3.6.7",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@redocly/cli": "^2.26.0",
    "@types/node": "^22.15.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
